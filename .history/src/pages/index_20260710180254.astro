---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
// Dữ liệu mẫu cho các bài viết. Sau này chúng ta có thể chuyển nó ra file riêng.
const posts = [
  {
    title: 'Dự án: Đo RPM xe máy bằng cảm biến Hall',
    description: 'Xây dựng một thiết bị đơn giản để đo vòng tua máy, ứng dụng vi điều khiển và lập trình C++.',
    href: '/projects/rpm-meter',
    category: 'Projects'
  },
  {
    title: 'Góc học tập: Tóm tắt "Tư duy nhanh và chậm"',
    description: 'Những ghi chú cốt lõi từ cuốn sách kinh điển của Daniel Kahneman về hai hệ thống tư duy của con người.',
    href: '/learning/thinking-fast-and-slow',
    category: 'Learning'
  },
  {
    title: 'Sáng tạo: Chế tạo loa Bluetooth từ ống nước PVC',
    description: 'Tận dụng vật liệu cũ để tạo ra một sản phẩm công nghệ hữu ích và độc đáo.',
    href: '/creative/pvc-bluetooth-speaker',
    category: 'Creative Sandbox'
  }
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>🧑‍🚀 Hello, Astronaut!</h1>
			<p>
				Welcome to the official <a href="https://astro.build/">Astro</a> blog starter template. This template
				serves as a lightweight, minimally-styled starting point for anyone looking to build a personal
				website, blog, or portfolio with Astro.
			</p>
			<p>
				This template comes with a few integrations already configured in your
				<code>astro.config.mjs</code> file. You can customize your setup with
				<a href="https://astro.build/integrations">Astro Integrations</a> to add tools like Tailwind,
				React, or Vue to your project.
			</p>
			<p>Here are a few ideas on how to get started with the template:</p>
			<ul>
				<li>Edit this page in <code>src/pages/index.astro</code></li>
				<li>Edit the site header items in <code>src/components/Header.astro</code></li>
				<li>Add your name to the footer in <code>src/components/Footer.astro</code></li>
				<li>Check out the included blog posts in <code>src/content/blog/</code></li>
				<li>Customize the blog post page layout in <code>src/layouts/BlogPost.astro</code></li>
			</ul>
			<p>
				Have fun! If you get stuck, remember to
				<a href="https://docs.astro.build/">read the docs</a>
				or <a href="https://astro.build/chat">join us on Discord</a> to ask questions.
			</p>
			<p>
				Looking for a blog template with a bit more personality? Check out
				<a href="https://github.com/Charca/astro-blog-template">astro-blog-template</a>
				by <a href="https://twitter.com/Charca">Maxi Ferreira</a>.
			</p>
		</main>
		<Footer />
	</body>
<html lang="vi">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>Trang chủ | Kỹ sư thực chiến</title>
        <meta name="description" content="Website cá nhân chia sẻ về các dự án kỹ thuật, ghi chú học tập và các sản phẩm sáng tạo." />
    </head>
    <body class="bg-gray-900 text-gray-100 font-sans">
        <!-- Header -->
        <header class="bg-gray-800/50 backdrop-blur-sm sticky top-0 z-10">
            <nav class="container mx-auto flex justify-between items-center p-4">
                <a href="/" class="text-xl font-bold hover:text-cyan-400 transition-colors">YourName</a>
                <div class="space-x-4 md:space-x-6">
                    <a href="/" class="hover:text-cyan-400 transition-colors">Home</a>
                    <a href="/projects" class="hover:text-cyan-400 transition-colors">Projects</a>
                    <a href="/learning" class="hover:text-cyan-400 transition-colors">Learning</a>
                    <a href="/creative" class="hover:text-cyan-400 transition-colors">Creative</a>
                </div>
            </nav>
        </header>

        <!-- Main Content -->
        <main class="container mx-auto p-4 md:p-8">
            <!-- Introduction -->
            <section class="text-center my-12 md:my-16">
                <h1 class="text-4xl md:text-5xl font-bold mb-4">Biến ý tưởng thành hiện thực.</h1>
                <p class="text-lg text-gray-400 max-w-2xl mx-auto">
                    Chào bạn, tôi là một kỹ sư đam mê giải quyết vấn đề. Tại đây, tôi chia sẻ hành trình của mình qua các dự án thực tế, những kiến thức chắt lọc và một vài sản phẩm sáng tạo "cây nhà lá vườn".
                </p>
            </section>

            <!-- Latest Posts -->
            <section>
                <h2 class="text-3xl font-bold mb-8 border-l-4 border-cyan-400 pl-4">Khám phá</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    {posts.map(post => (
                        <a href={post.href} class="block bg-gray-800 p-6 rounded-lg hover:ring-2 hover:ring-cyan-400 transition-all duration-300 transform hover:-translate-y-1">
                            <span class="text-sm font-semibold text-cyan-400">{post.category}</span>
                            <h3 class="text-xl font-bold mt-2 mb-2">{post.title}</h3>
                            <p class="text-gray-400">{post.description}</p>
                        </a>
                    ))}
                </div>
            </section>
        </main>

        <!-- Footer -->
        <footer class="text-center p-8 mt-16 border-t border-gray-800">
            <p class="text-gray-500">&copy; {new Date().getFullYear()} YourName. All rights reserved.</p>
        </footer>
    </body>
</html>
