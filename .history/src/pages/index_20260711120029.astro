---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import RpmHero from '../assets/RPM.jpg';
import LibraryHero from '../assets/LB1.png';

const latestActivity = [
    {
        title: 'Digital Motorcycle Tachometer (RPM Display System)',
        description: 'Developed a real-time RPM monitoring system for motorcycles, optimized for precise signal acquisition and long-term circuit reliability.',
        href: '/projects/rpm-meter',
        category: 'Project',
        image: RpmHero,
    },
        // Removed Library Management System project from Home
        // This project will be added to the Learning page instead
        // {
        //     title: 'Data Structures Project: Library Management System',
        //     description: 'A C++ data structures project focused on pointers, memory management, queues, and tree-based algorithm thinking.',
        //     href: '/projects/library-project',
        //     category: 'Project',
        //     image: LibraryHero,
        // },
];

const pageTitle = 'Home | YourName';
const pageDescription = 'A personal portfolio showcasing engineering projects, learning notes, and creative endeavors.';
---

<BaseLayout title={pageTitle} description={pageDescription}>
    <section class="text-center my-16 md:my-24">
        <h1 class="mb-4 bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-4xl font-bold text-transparent md:text-6xl">
            Turning Ideas into Reality.
        </h1>
        <p class="mx-auto max-w-2xl text-lg text-neutral-400">
            Hi, I'm an engineer who loves to solve problems and build things. This is where I document my journey through hands-on projects, distilled knowledge, and a few "home-brewed" creative works.
        </p>
    </section>

    <section>
        <h2 class="mb-8 border-l-4 border-cyan-400 pl-4 text-3xl font-bold">Latest Activity</h2>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-2">
            {latestActivity.map((item) => (
                <a href={item.href} class="group overflow-hidden rounded-3xl border border-neutral-800 bg-neutral-900/80 transition-all duration-300 hover:-translate-y-1 hover:border-cyan-400/40 hover:shadow-2xl hover:shadow-cyan-950/20">
                    <Image src={item.image} alt={item.title} class="h-48 w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]" />
                    <div class="p-6">
                        <span class="text-sm font-semibold text-cyan-400">{item.category}</span>
                        <h3 class="mb-2 mt-2 text-xl font-bold text-neutral-100">{item.title}</h3>
                        <p class="text-neutral-400">{item.description}</p>
                    </div>
                </a>
            ))}
        </div>
    </section>
</BaseLayout>
