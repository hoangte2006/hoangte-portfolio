---
import { type CollectionEntry, getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LibraryHero from '../../assets/LB1.png';
import RpmXeCover from '../../assets/RPM-Xe/RPM_XE (8).jpg';
import RpmXe1 from '../../assets/RPM-Xe/RPM_XE (1).jpg';
import RpmXe2 from '../../assets/RPM-Xe/RPM_XE (2).jpg';
import RpmXe3 from '../../assets/RPM-Xe/RPM_XE (3).jpg';
import RpmXe4 from '../../assets/RPM-Xe/RPM_XE (4).jpg';
import RpmXe5 from '../../assets/RPM-Xe/RPM_XE (5).jpg';
import RpmXe6 from '../../assets/RPM-Xe/RPM_XE (6).jpg';
import RpmXe7 from '../../assets/RPM-Xe/RPM_XE (7).jpg';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.slug },
		props: project,
	}));
}
type Props = CollectionEntry<'projects'>;

const project = Astro.props;
const { Content } = await project.render();

const isRpmProject = project.slug === 'rpm-meter';
const isLibraryProject = project.slug === 'library-project';

const rpmVideos = [
	'https://www.youtube.com/watch?v=fnMK_4SRYB4&list=PLPGzYWS3E4fg&index=1',
	'https://www.youtube.com/watch?v=liEPrdCWsI8&list=PLPGzYWS3E4fg&index=2',
	'https://www.youtube.com/watch?v=6Vn4U4ADo1Q&list=PLPGzYWS3E4fg&index=3',
];

const rpmGallery = [
	{ src: RpmXe1, alt: 'RPM-Xe build photo 1' },
	{ src: RpmXe2, alt: 'RPM-Xe build photo 2' },
	{ src: RpmXe3, alt: 'RPM-Xe build photo 3' },
	{ src: RpmXe4, alt: 'RPM-Xe build photo 4' },
	{ src: RpmXe5, alt: 'RPM-Xe build photo 5' },
	{ src: RpmXe6, alt: 'RPM-Xe build photo 6' },
	{ src: RpmXe7, alt: 'RPM-Xe build photo 7' },
];

const getYouTubeEmbedUrl = (url: string) => {
	const parsedUrl = new URL(url);
	const videoId = parsedUrl.searchParams.get('v') ?? parsedUrl.pathname.split('/').filter(Boolean).pop();

	return videoId ? `https://www.youtube.com/embed/${videoId}` : url;
};

const youtubeVideos = (project.data.youtube?.length ? project.data.youtube : isRpmProject ? rpmVideos : []).map((url) => ({
	url,
	embedUrl: getYouTubeEmbedUrl(url),
})) ?? [];

const heroImage = isRpmProject ? RpmXeCover : isLibraryProject ? LibraryHero : undefined;
---

<BaseLayout title={project.data.title} description={project.data.description}>
	<article class="project-article space-y-10">
		<header class="rounded-3xl border border-neutral-800 bg-gradient-to-br from-neutral-900 via-neutral-900 to-slate-950 p-6 shadow-2xl shadow-cyan-950/20 md:p-8">
			<div class="mb-4 flex flex-wrap items-center gap-3 text-sm text-neutral-300">
				<span class="rounded-full border border-cyan-400/30 bg-cyan-400/10 px-3 py-1 text-cyan-300">Project</span>
				<span class="rounded-full border border-neutral-700 bg-neutral-800/70 px-3 py-1">{project.data.period}</span>
			</div>
			<h1 class="mb-4 bg-gradient-to-r from-cyan-300 via-white to-blue-300 bg-clip-text text-4xl font-bold tracking-tight text-transparent md:text-6xl">
				{project.data.title}
			</h1>
			<p class="max-w-3xl text-lg leading-relaxed text-neutral-300 md:text-xl">
				{project.data.description}
			</p>
		</header>

		<section class="space-y-6">
			{heroImage && (
				<div class="hero-media overflow-hidden rounded-3xl border border-neutral-800 bg-neutral-950">
					<Image
						src={heroImage}
						alt={`Cover image for ${project.data.title}`}
						width={1400}
						height={788}
						class="h-auto w-full object-cover"
					/>
				</div>
			)}

			{youtubeVideos.length > 0 && (
				<div class="grid gap-6 lg:grid-cols-2">
					{youtubeVideos.slice(0, 2).map((video, index) => (
						<div class="overflow-hidden rounded-3xl border border-neutral-800 bg-black">
							<div class="relative w-full" style="aspect-ratio: 16 / 9; min-height: 360px;">
								<iframe
									src={video.embedUrl}
									title={`RPM demo video ${index + 1}`}
									class="absolute inset-0 h-full w-full"
									loading="lazy"
									allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
									allowfullscreen
								/>
							</div>
						<div class="flex items-center justify-between gap-3 border-t border-neutral-800 px-4 py-3 text-sm text-neutral-300">
							<span>Video {index + 1}</span>
							<a href={video.url} target="_blank" rel="noreferrer" class="text-sky-300 transition-colors hover:text-sky-200">Open on YouTube</a>
						</div>
					</div>
					))}
				</div>
			)}
		</section>

		<div class="prose prose-invert prose-lg max-w-none rounded-3xl border border-neutral-800 bg-neutral-900/70 p-6 prose-headings:text-cyan-300 prose-a:text-sky-300 hover:prose-a:text-sky-200 prose-strong:text-neutral-100 prose-blockquote:border-l-cyan-400 prose-blockquote:text-neutral-300 md:p-8">
			<Content />

			{isRpmProject && (
				<section class="not-prose mt-10">
					<h3 class="mb-4 text-2xl font-bold text-cyan-300">RPM-Xe Build Gallery</h3>
					<div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
						{rpmGallery.map((photo, index) => (
							<figure class="overflow-hidden rounded-2xl border border-neutral-800 bg-black/40">
								<Image src={photo.src} alt={photo.alt} class="h-64 w-full object-cover" />
								<figcaption class="border-t border-neutral-800 px-4 py-2 text-sm text-neutral-300">
									Build photo {index + 1}
								</figcaption>
							</figure>
						))}
					</div>
				</section>
			)}

			<div class="not-prose mt-10 rounded-2xl border border-cyan-400/20 bg-cyan-400/5 p-6">
				<h3 class="mb-3 text-2xl font-bold text-cyan-300">Outcome</h3>
				<p class="text-lg leading-relaxed text-neutral-200">{project.data.outcome}</p>
			</div>
		</div>

		{youtubeVideos.length > 2 && (
			<section class="grid gap-6 lg:grid-cols-2">
				{youtubeVideos.slice(2).map((video, index) => (
					<div class="overflow-hidden rounded-3xl border border-neutral-800 bg-black">
						<div class="relative w-full" style="aspect-ratio: 16 / 9; min-height: 360px;">
							<iframe
								src={video.embedUrl}
								title={`RPM demo video ${index + 3}`}
								class="absolute inset-0 h-full w-full"
								loading="lazy"
								allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
								allowfullscreen
							/>
						</div>
						<div class="flex items-center justify-between gap-3 border-t border-neutral-800 px-4 py-3 text-sm text-neutral-300">
							<span>Video {index + 3}</span>
							<a href={video.url} target="_blank" rel="noreferrer" class="text-sky-300 transition-colors hover:text-sky-200">Open on YouTube</a>
						</div>
					</div>
				))}
			</section>
		)}
	</article>

	<style>
		.project-article :global(.prose img) {
			display: block;
			width: 100%;
			max-width: 760px;
			height: auto;
			margin: 1.5rem auto;
			border-radius: 1.25rem;
			border: 1px solid rgb(38 38 38 / 1);
			box-shadow: 0 18px 40px rgb(0 0 0 / 0.25);
		}

		.project-article .hero-media {
			max-width: 760px;
			margin: 0 auto;
		}
	</style>
</BaseLayout>