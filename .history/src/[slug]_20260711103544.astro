---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.slug },
		props: project,
	}));
}
type Props = CollectionEntry<'projects'>;

const project = Astro.props;
const { Content } = await project.render();
---

<BaseLayout title={project.data.title} description={project.data.description}>
	<article>
		<header class="mb-12">
			<h1 class="text-4xl md:text-5xl font-bold mb-2">{project.data.title}</h1>
			<p class="text-neutral-400 text-lg">{project.data.period}</p>
		</header>

		<div class="prose prose-invert prose-lg max-w-none 
					prose-headings:text-cyan-400 prose-a:text-blue-400 hover:prose-a:text-blue-300
					prose-strong:text-neutral-200 prose-blockquote:border-l-cyan-400">
			<p class="lead text-xl text-neutral-300">{project.data.description}</p>
			
			<Content />

			<div class="mt-12 p-6 bg-neutral-800/50 rounded-lg">
				<h3 class="text-2xl font-bold text-cyan-400 mb-3">Outcome</h3>
				<p class="text-lg text-neutral-300">{project.data.outcome}</p>
			</div>
		</div>

	</article>
</BaseLayout>